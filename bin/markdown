#!/usr/bin/env bash

if [[ $# -eq 0 ]]; then
  echo "Usage: markdown <file>" >&2
  exit 1
fi

file="$1"

if [[ ! -f "$file" ]]; then
  echo "Error: '$file': no such file" >&2
  exit 1
fi

ext=".${file##*.}"

case "$ext" in
  .md|.markdown|.mdown|.mkd)
    open -a "Google Chrome" "$file"
    ;;
  *)
    echo "Error: '$file': not a markdown file (.md, .markdown, .mdown, .mkd)" >&2
    exit 1
    ;;
esac
