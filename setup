#!/bin/bash

ABSPATH=$(cd ${0%/*} && echo `pwd`/${0##*/})
CWD=`dirname "$ABSPATH"`

function link {
    srcfile="$CWD/$1"
    destfile="$HOME/"

    ln -sfnv $srcfile $destfile
}

for file in .*; do
    if [ . != $file ] && [ .. != $file ] && [ '.gitignore' != $file ] && [ '.git' != $file ] && [ 'swp' != ${file##*.} ]; then
        #link $file
        echo $file
    fi
done

for file in bin/*; do
    if [ ! -L "$HOME/$file" ]; then
        ln -sfnv "$CWD/$file" "$HOME/$file"
    fi
done

# Claude Code
mkdir -p "$HOME/.claude"
ln -sfnv "$CWD/.claude/settings.json" "$HOME/.claude/settings.json"
if [ -d "$HOME/.claude/hooks" ] && [ ! -L "$HOME/.claude/hooks" ]; then
    echo "Warning: $HOME/.claude/hooks already exists as a real directory, skipping symlink."
else
    ln -sfnv "$CWD/.claude/hooks" "$HOME/.claude/hooks"
fi

osascript -e 'display notification "dotfiles 設定完成" with title "dotfiles setup ✅" sound name "Glass"' || true
